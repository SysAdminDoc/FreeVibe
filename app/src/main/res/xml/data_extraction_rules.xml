        <exclude domain="sharedpref" path="freevibe_dark_mode.xml" />
        <exclude domain="sharedpref" path="freevibe_live_wp.xml" />
        <exclude domain="sharedpref" path="freevibe_weather_wp.xml" />
        <exclude domain="database" path="freevibe.db-journal" />
        <exclude domain="database" path="freevibe.db-shm" />
        <exclude domain="database" path="freevibe.db-wal" />
        <exclude domain="file" path="datastore/freevibe_prefs.preferences_pb" />
        <exclude domain="file" path="crash.log" />
