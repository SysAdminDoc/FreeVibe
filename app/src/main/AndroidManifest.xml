<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Wallpaper -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <!-- Ringtone/Notification/Alarm -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage (scoped per API level) -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Scheduling -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- NX-6: RotationTriggerService runs as a long-lived foreground service to
         dynamically register USER_PRESENT and SCREEN_OFF receivers (those broadcasts
         can't be observed via manifest registration on Android 8+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Location (weather effects) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Contacts (per-contact ringtones) -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- Live wallpaper not required -->
    <uses-feature
        android:name="android.software.live_wallpaper"
        android:required="false" />

    <application
        android:name=".FreeVibeApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.FreeVibe"
        android:usesCleartextTraffic="false"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FreeVibe">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="collection"
                    android:scheme="aura" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:mimeType="application/json"
                    android:scheme="content" />
                <data
                    android:mimeType="application/json"
                    android:scheme="file" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/json" />
            </intent-filter>
        </activity>

        <!-- Video Live Wallpaper Service -->
        <service
            android:name=".service.VideoWallpaperService"
            android:exported="true"
            android:label="@string/video_wallpaper_label"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/video_wallpaper" />
        </service>

        <!-- Weather Live Wallpaper Service -->
        <service
            android:name=".service.WeatherWallpaperService"
            android:exported="true"
            android:label="Aura Weather"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/weather_wallpaper" />
        </service>

        <!-- Parallax Depth Live Wallpaper Service -->
        <service
            android:name=".service.ParallaxWallpaperService"
            android:exported="true"
            android:label="Aura Parallax"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/parallax_wallpaper" />
        </service>

        <!-- Audio Playback Service (MediaSession) -->
        <service
            android:name=".service.AudioPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- NX-6: Rotation trigger service — listens for USER_PRESENT / SCREEN_OFF
             and enqueues one-shot AutoWallpaperWorker rotations. specialUse type
             with the property below documents why we sit foreground long-term.
             Off by default; only started when the user opts in via Settings. -->
        <service
            android:name=".service.RotationTriggerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="wallpaper_rotation_triggers" />
        </service>

        <!-- L-2 Tasker / automation hook: broadcast receiver exposing
             ROTATE_NOW + SHUFFLE_NOW intents. Exported so Tasker, MacroDroid,
             adb shell etc. can fire them. No custom permission — same trust
             surface as the widget's tap-to-shuffle. -->
        <receiver
            android:name=".service.TaskerActionReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.freevibe.action.ROTATE_NOW" />
                <action android:name="com.freevibe.action.SHUFFLE_NOW" />
            </intent-filter>
        </receiver>

        <!-- Home Screen Widget -->
        <receiver
            android:name=".widget.FreeVibeWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/freevibe_widget_info" />
        </receiver>

        <!-- FileProvider for sharing files with system apps -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Auto Wallpaper Worker -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
